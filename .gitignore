# Rust build artifacts
# Use a glob so both /target and /hex-ls/target are covered.
target/

# extension.wasm is generated by Zed during dev-extension compilation.
# It is not source and will differ per machine/toolchain.
extension.wasm

# hex-ls is a workspace member, so Cargo uses the root Cargo.lock.
# This file is a leftover from standalone development and is ignored.
hex-ls/Cargo.lock

# Note: the root Cargo.lock IS tracked. This project ships a binary
# (hex-ls), so committing the lock file gives reproducible installs.

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
